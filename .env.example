# --- COMMON CONFIGURATION ---
NODE_ENV=development
LOG_LEVEL=info

# --- DATABASE (PostgreSQL) ---
# Used by Docker Compose for the postgres service
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_DATABASE=fullstack_db

# Used by Backend & Worker to connect to the DB
# In Docker, DB_HOST should be 'postgres'
# In local development, DB_HOST should be '127.0.0.1'
DB_HOST=postgres
DB_PORT=5432
DB_CONNECTION=pgsql

# --- REDIS / BULLMQ ---
# In Docker, REDIS_HOST should be 'redis'
# In local development, REDIS_HOST should be '127.0.0.1'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_DB=0

# --- STORAGE (S3 / MinIO) ---
# Set these to enable S3 storage for Excel files. If not set, local storage is used.
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=your_minio_access_key
S3_SECRET_KEY=your_minio_secret_key
S3_BUCKET=inventory-vouchers
S3_FORCE_PATH_STYLE=true
EXCEL_S3_FILE_TTL_SECONDS=1800

# S3 Template Keys (paths within the bucket)
S3_VOUCHER_FORM_TEMPLATE_KEY=templates/phieu_nhap_kho.xlsx
S3_VOUCHER_LIST_TEMPLATE_KEY=templates/danh_sach_phieu_nhap_kho.xlsx

# Legacy AWS variable names (if needed)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${S3_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${S3_SECRET_KEY}

# --- BACKEND ---
PORT=4000
PUBLIC_APP_ORIGIN=http://localhost:3000
EXCEL_IMPORT_UPLOAD_DIR=storage/imports

# --- WORKER ---
WORKER_CONCURRENCY=2
EXCEL_EXPORT_DIR=storage/exports
# Absolute path shared with backend when not using S3 (single-node dev)
# EXCEL_SHARED_EXPORT_DIR=/absolute/path/to/worker/storage/exports
VOUCHER_TEMPLATE_HOST_PATH=./packages/templates/phieu_nhap_kho.xlsx
INVENTORY_VOUCHER_TEMPLATE_PATH=/templates/phieu_nhap_kho.xlsx
WORKER_HEALTH_PORT=9090
EXCEL_EXPORT_BATCH_SIZE=5000
EXCEL_IMPORT_BATCH_SIZE=1000

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_PORT=3000
