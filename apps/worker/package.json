{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run build -w @repo/db && npm run build -w @repo/storage",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "npm run build -w @repo/db && npm run build -w @repo/storage",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/index.js",
    "upload-templates": "ts-node --project tsconfig.script.json scripts/upload-templates.ts",
    "pretest": "npm run build -w @repo/types && npm run build -w @repo/db && npm run build -w @repo/storage",
    "test": "jest --config jest.config.cjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@repo/db": "*",
    "@repo/storage": "*",
    "@repo/types": "*",
    "bullmq": "^5.76.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "^0.0.0",
    "@repo/typescript-config": "^0.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=24"
  }
}
