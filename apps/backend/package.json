{
  "name": "backend",
  "version": "0.1.0",
  "main": "dist/server.js",
  "scripts": {
    "pretest": "npm run build -w @repo/types && npm run build -w @repo/db && npm run build -w @repo/storage",
    "test": "jest",
    "predev": "npm run build -w @repo/types && npm run build -w @repo/db && npm run build -w @repo/storage",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "prebuild": "npm run build -w @repo/types && npm run build -w @repo/db && npm run build -w @repo/storage",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "eslint .",
    "migrate": "npx node-pg-migrate",
    "migrate:create": "node-pg-migrate create",
    "seed:1m": "ts-node-dev --transpile-only seeders/seeding_1m.ts",
    "seed:prod": "node dist/seeders/seeding_1m.js",
    "seed:test": "ts-node-dev --transpile-only seeders/seeding_1m.ts --count=100"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "private": "true",
  "devDependencies": {
    "@repo/eslint-config": "^0.0.0",
    "@repo/types": "*",
    "@repo/typescript-config": "^0.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "node-pg-migrate": "^8.0.4",
    "pg-mem": "^3.0.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@repo/db": "*",
    "@repo/storage": "*",
    "cors": "^2.8.6",
    "bullmq": "^5.65.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.8.2",
    "multer": "^2.0.2",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
