{
  "name": "test-03052026",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "npm run test -w worker && npm run test -w backend && npm run test -w web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "seed:1m": "npm run seed:prod -w backend",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
